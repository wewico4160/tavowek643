<?xml version="1.0" encoding="utf-8"?>
<tt
  xmlns="http://www.w3.org/ns/ttml"
  xmlns:ttm="http://www.w3.org/ns/ttml#metadata"
  xmlns:tts="http://www.w3.org/ns/ttml#styling"
  xmlns:ttp="http://www.w3.org/ns/ttml#parameter"
  ttp:cellResolution="384 288"
  xml:lang="eng">
  <head>
    <layout>
      <region xml:id="Default"
        tts:origin="3% 0%"
        tts:extent="97% 97%"
        tts:displayAlign="after"
        tts:textAlign="center"
        tts:fontSize="16c"
        tts:fontFamily="Arial"
        tts:overflow="visible" />
    </layout>
  </head>
  <body>
    <div>
      <p
        begin="00:00:04.171"
        end="00:00:08.884"><span region="Default">[Taylor] ♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:00:08.967"
        end="00:00:10.969"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:00:14.681"
        end="00:00:19.728"><span region="Default">♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:00:31.031"
        end="00:00:34.743"><span region="Default">♪ It's been a long time ♪</span></p>
      <p
        begin="00:00:35.994"
        end="00:00:39.373"><span region="Default">-♪ It's you and me ♪<br/>-[cheering continues]</span></p>
      <p
        begin="00:00:43.252"
        end="00:00:48.090"><span region="Default">♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:00:52.803"
        end="00:00:56.348"><span region="Default">♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:00:57.975"
        end="00:01:00.060"><span region="Default">♪ What if I told you I'm back? ♪</span></p>
      <p
        begin="00:01:00.143"
        end="00:01:02.229"><span region="Default">♪ It's fearless<br/>It's you and me ♪</span></p>
      <p
        begin="00:01:02.312"
        end="00:01:05.816"><span region="Default">♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:01:07.776"
        end="00:01:10.863"><span region="Default">♪ Big reputation<br/>It's been a long time coming ♪</span></p>
      <p
        begin="00:01:12.364"
        end="00:01:17.786"><span region="Default">♪ And they said, "Speak now"<br/>It's been a long time coming ♪</span></p>
      <p
        begin="00:01:18.745"
        end="00:01:20.581"><span region="Default">♪ Into folklore ♪</span></p>
      <p
        begin="00:01:21.832"
        end="00:01:25.627"><span region="Default">My name is Taylor and I was born in 1989.</span></p>
      <p
        begin="00:01:27.254"
        end="00:01:30.299"><span region="Default">♪ Straight from<br/>the tortured poets department ♪</span></p>
      <p
        begin="00:01:31.383"
        end="00:01:33.010"><span region="Default">♪ It's been a long time coming ♪</span></p>
      <p
        begin="00:01:33.093"
        end="00:01:36.346"><span region="Default">♪ Lovin' him was red<br/>It's been a long time coming ♪</span></p>
      <p
        begin="00:01:38.265"
        end="00:01:39.600"><span region="Default">♪ Red ♪</span></p>
      <p
        begin="00:01:39.683"
        end="00:01:41.476"><span region="Default">♪ It's you and me<br/>It's been a long time coming ♪</span></p>
      <p
        begin="00:01:41.560"
        end="00:01:43.145"><span region="Default">♪ Meet me at midnight ♪</span></p>
      <p
        begin="00:01:46.857"
        end="00:01:47.858"><span region="Default">♪ Nice ♪</span></p>
      <p
        begin="00:01:48.609"
        end="00:01:50.235"><span region="Default">♪ Lover ♪</span></p>
      <p
        begin="00:01:50.319"
        end="00:01:52.863"><span region="Default">♪ It's been a long time coming, but ♪</span></p>
      <p
        begin="00:01:52.946"
        end="00:01:55.324"><span region="Default">♪ It's you and me, that's my whole world ♪</span></p>
      <p
        begin="00:01:55.407"
        end="00:01:58.785"><span region="Default">♪ They whisper down the hallway<br/>she's a bad, bad girl ♪</span></p>
      <p
        begin="00:01:58.869"
        end="00:02:01.830"><span region="Default">♪ The whole school is rolling fake dice ♪</span></p>
      <p
        begin="00:02:01.914"
        end="00:02:05.250"><span region="Default">♪ You play stupid games,<br/>you win stupid prizes ♪</span></p>
      <p
        begin="00:02:05.334"
        end="00:02:08.003"><span region="Default">♪ It's you and me,<br/>there's nothing like this ♪</span></p>
      <p
        begin="00:02:08.086"
        end="00:02:11.340"><span region="Default">♪ Miss Americana<br/>and The Heartbreak Prince ♪</span></p>
      <p
        begin="00:02:11.423"
        end="00:02:14.593"><span region="Default">-♪ Okay ♪<br/>-♪ We're so sad, we paint the town blue ♪</span></p>
      <p
        begin="00:02:14.676"
        end="00:02:18.055"><span region="Default">♪ Voted most likely to run away ♪</span></p>
      <p
        begin="00:02:18.138"
        end="00:02:21.099"><span region="Default">♪ Voted most likely to run away ♪</span></p>
      <p
        begin="00:02:21.183"
        end="00:02:24.436"><span region="Default">♪ Voted most likely to run away ♪</span></p>
      <p
        begin="00:02:24.520"
        end="00:02:28.732"><span region="Default">♪ Voted most likely to run away ♪</span></p>
      <p
        begin="00:02:30.651"
        end="00:02:33.904"><span region="Default">♪ With you ♪</span></p>
      <p
        begin="00:02:39.326"
        end="00:02:40.536"><span region="Default">Oh, hi!</span></p>
      <p
        begin="00:02:40.619"
        end="00:02:42.037"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:02:42.120"
        end="00:02:44.122"><span region="Default">[♪ "Cruel Summer" playing]</span></p>
      <p
        begin="00:02:45.249"
        end="00:02:47.501"><span region="Default">♪ Fever dream high<br/>in the quiet of the night ♪</span></p>
      <p
        begin="00:02:47.584"
        end="00:02:48.961"><span region="Default">♪ You know that I caught it ♪</span></p>
      <p
        begin="00:02:49.044"
        end="00:02:50.254"><span region="Default">♪ You're right I want it ♪</span></p>
      <p
        begin="00:02:50.337"
        end="00:02:54.633"><span region="Default">♪ Bad, bad boy, shiny toy with a price<br/>You know that I bought it ♪</span></p>
      <p
        begin="00:02:54.716"
        end="00:02:55.717"><span region="Default">♪ You're right, I want it ♪</span></p>
      <p
        begin="00:02:55.801"
        end="00:02:58.262"><span region="Default">♪ Killing me slow, out the window ♪</span></p>
      <p
        begin="00:02:58.345"
        end="00:03:00.889"><span region="Default">♪ I'm always waiting for you<br/>to be waiting below ♪</span></p>
      <p
        begin="00:03:00.973"
        end="00:03:03.851"><span region="Default">♪ Devils roll the dice,<br/>angels roll their eyes ♪</span></p>
      <p
        begin="00:03:03.934"
        end="00:03:06.979"><span region="Default">♪ What doesn't kill me<br/>makes me want you more ♪</span></p>
      <p
        begin="00:03:07.062"
        end="00:03:13.110"><span region="Default">♪ And it's new, the shape of your body<br/>It's blue, the feeling I've got ♪</span></p>
      <p
        begin="00:03:13.193"
        end="00:03:18.615"><span region="Default">♪ And it's ooh, whoa-oh<br/>It's a cruel summer ♪</span></p>
      <p
        begin="00:03:18.699"
        end="00:03:24.246"><span region="Default">♪ It's cool, that's what I tell 'em<br/>No rules in breakable heaven ♪</span></p>
      <p
        begin="00:03:24.329"
        end="00:03:31.003"><span region="Default">♪ But ooh, whoa-oh<br/>It's a cruel summer with you ♪</span></p>
      <p
        begin="00:03:32.880"
        end="00:03:36.091"><span region="Default">♪ Hang your head low in the glow<br/>of the vending machine ♪</span></p>
      <p
        begin="00:03:36.175"
        end="00:03:38.510"><span region="Default">-♪ I'm not dying ♪<br/>-♪ You're right, I want it ♪</span></p>
      <p
        begin="00:03:38.594"
        end="00:03:41.680"><span region="Default">♪ You say that we'll just screw it up<br/>in these trying times ♪</span></p>
      <p
        begin="00:03:41.763"
        end="00:03:44.141"><span region="Default">-♪ We're not trying ♪<br/>-♪ You're right, I want it ♪</span></p>
      <p
        begin="00:03:44.224"
        end="00:03:46.393"><span region="Default">♪ So cut the headlights,<br/>summer's a knife ♪</span></p>
      <p
        begin="00:03:46.476"
        end="00:03:49.104"><span region="Default">♪ I'm always waiting for you<br/>just to cut to the bone ♪</span></p>
      <p
        begin="00:03:49.188"
        end="00:03:52.065"><span region="Default">♪ Devils roll the dice,<br/>angels roll their eyes ♪</span></p>
      <p
        begin="00:03:52.149"
        end="00:03:54.735"><span region="Default">♪ And if I bleed,<br/>you'll be the last to know ♪</span></p>
      <p
        begin="00:03:54.818"
        end="00:04:00.699"><span region="Default">♪ Oh, it's new, the shape of your body<br/>It's blue, the feeling I've got it ♪</span></p>
      <p
        begin="00:04:00.782"
        end="00:04:06.205"><span region="Default">♪ And it's ooh, whoa-oh<br/>It's a cruel summer ♪</span></p>
      <p
        begin="00:04:06.288"
        end="00:04:12.085"><span region="Default">♪ It's cool, that's what I tell 'em<br/>No rules in breakable heaven ♪</span></p>
      <p
        begin="00:04:12.169"
        end="00:04:18.800"><span region="Default">♪ But ooh, whoa-oh<br/>It's a cruel summer with you ♪</span></p>
      <p
        begin="00:04:18.884"
        end="00:04:21.595"><span region="Default">All right, Vancouver, we have arrived.</span></p>
      <p
        begin="00:04:21.678"
        end="00:04:23.305"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:04:24.848"
        end="00:04:26.934"><span region="Default">At the very first bridge of the evening.</span></p>
      <p
        begin="00:04:27.017"
        end="00:04:28.268"><span region="Default">Now, I have a question.</span></p>
      <p
        begin="00:04:28.894"
        end="00:04:32.689"><span region="Default">Would any of you beautiful people<br/>happen to know the lyrics to this bridge?</span></p>
      <p
        begin="00:04:33.607"
        end="00:04:34.900"><span region="Default">Ha. Prove it!</span></p>
      <p
        begin="00:04:35.484"
        end="00:04:37.569"><span region="Default">♪ I'm drunk in the back of the car ♪</span></p>
      <p
        begin="00:04:37.653"
        end="00:04:40.030"><span region="Default">♪ And I cried like a baby<br/>coming home from the bar ♪</span></p>
      <p
        begin="00:04:40.113"
        end="00:04:41.365"><span region="Default">♪ Oh ♪</span></p>
      <p
        begin="00:04:41.448"
        end="00:04:43.325"><span region="Default">♪ I'm fine but it wasn't true ♪</span></p>
      <p
        begin="00:04:43.408"
        end="00:04:46.245"><span region="Default">♪ I don't wanna keep secrets<br/>just to keep you ♪</span></p>
      <p
        begin="00:04:46.328"
        end="00:04:48.789"><span region="Default">♪ And I snuck in through the garden gate ♪</span></p>
      <p
        begin="00:04:48.872"
        end="00:04:51.750"><span region="Default">♪ Every night that summer<br/>just to seal my fate ♪</span></p>
      <p
        begin="00:04:51.834"
        end="00:04:52.835"><span region="Default">♪ Oh ♪</span></p>
      <p
        begin="00:04:52.918"
        end="00:04:54.545"><span region="Default">♪ And I screamed for whatever it's worth ♪</span></p>
      <p
        begin="00:04:54.628"
        end="00:04:58.090"><span region="Default">♪ I love you, ain't that the worst thing<br/>you ever heard? ♪</span></p>
      <p
        begin="00:04:58.173"
        end="00:05:00.634"><span region="Default">♪ He looks up grinning like a devil ♪</span></p>
      <p
        begin="00:05:00.717"
        end="00:05:05.639"><span region="Default">♪ It's new, the shape of your body<br/>It's blue, the feeling I've got ♪</span></p>
      <p
        begin="00:05:05.722"
        end="00:05:11.270"><span region="Default">♪ And it's ooh,<br/>whoa-oh It's a cruel summer ♪</span></p>
      <p
        begin="00:05:11.353"
        end="00:05:17.067"><span region="Default">♪ It's cool, that's what I tell 'em<br/>No rules in breakable heaven ♪</span></p>
      <p
        begin="00:05:17.150"
        end="00:05:22.781"><span region="Default">♪ But ooh, whoa-oh<br/>It's a cruel summer ♪</span></p>
      <p
        begin="00:05:23.615"
        end="00:05:25.534"><span region="Default">♪ I'm drunk in the back of the car ♪</span></p>
      <p
        begin="00:05:25.617"
        end="00:05:28.370"><span region="Default">♪ And I cried like a baby<br/>coming home from the bar ♪</span></p>
      <p
        begin="00:05:28.453"
        end="00:05:29.621"><span region="Default">-♪ Oh ♪<br/>-♪ Said I'm fine ♪</span></p>
      <p
        begin="00:05:29.705"
        end="00:05:31.248"><span region="Default">♪ But it wasn't true ♪</span></p>
      <p
        begin="00:05:31.331"
        end="00:05:34.418"><span region="Default">♪ I don't wanna keep secrets<br/>just to keep you ♪</span></p>
      <p
        begin="00:05:34.501"
        end="00:05:36.670"><span region="Default">♪ And I snuck in through the garden gate ♪</span></p>
      <p
        begin="00:05:36.753"
        end="00:05:39.506"><span region="Default">♪ Every night that summer<br/>just to seal my fate ♪</span></p>
      <p
        begin="00:05:39.590"
        end="00:05:41.216"><span region="Default">-♪ Oh ♪<br/>-♪ And I screamed ♪</span></p>
      <p
        begin="00:05:41.300"
        end="00:05:42.885"><span region="Default">♪ For whatever it's worth ♪</span></p>
      <p
        begin="00:05:42.968"
        end="00:05:46.680"><span region="Default">♪ I love you, ain't that the worst thing<br/>you ever heard ♪</span></p>
      <p
        begin="00:05:49.725"
        end="00:05:51.602"><span region="Default">♪ Cruel summer with you ♪</span></p>
      <p
        begin="00:05:51.685"
        end="00:05:54.688"><span region="Default">-♪ With you, with you, with you ♪<br/>-♪ With you ♪</span></p>
      <p
        begin="00:05:54.771"
        end="00:05:57.107"><span region="Default">-♪ With you, with you, with you ♪<br/>-♪ With you ♪</span></p>
      <p
        begin="00:05:57.191"
        end="00:05:59.651"><span region="Default">♪ With you, with you, with you ♪</span></p>
      <p
        begin="00:05:59.735"
        end="00:06:03.238"><span region="Default">♪ It's a cruel summer with you ♪</span></p>
      <p
        begin="00:06:03.322"
        end="00:06:06.033"><span region="Default">-♪ With you, with you, with you ♪<br/>-♪ With you ♪</span></p>
      <p
        begin="00:06:06.116"
        end="00:06:09.119"><span region="Default">-♪ With you, with you, with you ♪<br/>-♪ With you ♪</span></p>
      <p
        begin="00:06:09.203"
        end="00:06:11.038"><span region="Default">♪ With you, with you, with you ♪</span></p>
      <p
        begin="00:06:11.121"
        end="00:06:15.751"><span region="Default">♪ It's a cruel summer ♪</span></p>
      <p
        begin="00:06:15.834"
        end="00:06:16.960"><span region="Default">-[♪ song ends]<br/>-[crowd cheering]</span></p>
      <p
        begin="00:06:51.245"
        end="00:06:52.246"><span region="Default">[cheering continues]</span></p>
      <p
        begin="00:06:53.872"
        end="00:06:54.873"><span region="Default">[imperceptible]</span></p>
      <p
        begin="00:07:24.319"
        end="00:07:27.823"><span region="Default">So, it's feeling like it's a pretty cool<br/>night to be in Vancouver, huh?</span></p>
      <p
        begin="00:07:28.782"
        end="00:07:29.825"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:07:29.908"
        end="00:07:30.909"><span region="Default">[♪ musical flourish]</span></p>
      <p
        begin="00:07:46.341"
        end="00:07:47.885"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:07:59.771"
        end="00:08:00.856"><span region="Default">Okay, that was pretty awesome.</span></p>
      <p
        begin="00:08:00.939"
        end="00:08:02.149"><span region="Default">That was, uh,</span></p>
      <p
        begin="00:08:03.150"
        end="00:08:05.277"><span region="Default">honestly like that<br/>whole first five minutes</span></p>
      <p
        begin="00:08:05.360"
        end="00:08:07.321"><span region="Default">of the way you've been treating me<br/>out here, you're...</span></p>
      <p
        begin="00:08:09.156"
        end="00:08:11.116"><span region="Default">I mean, you're really incredible.</span></p>
      <p
        begin="00:08:11.200"
        end="00:08:13.118"><span region="Default">Like, the way you're treating me, I'm...</span></p>
      <p
        begin="00:08:13.202"
        end="00:08:14.286"><span region="Default">I'm actually a little worried,</span></p>
      <p
        begin="00:08:14.369"
        end="00:08:17.247"><span region="Default">it's starting to immediately<br/>go to my head now.</span></p>
      <p
        begin="00:08:17.331"
        end="00:08:19.082"><span region="Default">And I'm... I'm like...</span></p>
      <p
        begin="00:08:23.337"
        end="00:08:27.466"><span region="Default">I mean, you got me<br/>feeling really, really...</span></p>
      <p
        begin="00:08:30.177"
        end="00:08:31.345"><span region="Default">powerful.</span></p>
      <p
        begin="00:08:31.428"
        end="00:08:32.429"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:08:36.099"
        end="00:08:37.726"><span region="Default">[♪ guitar solo playing]</span></p>
      <p
        begin="00:08:56.870"
        end="00:08:57.913"><span region="Default">I mean,</span></p>
      <p
        begin="00:08:59.414"
        end="00:09:01.375"><span region="Default">you're making me feel like tonight</span></p>
      <p
        begin="00:09:02.251"
        end="00:09:05.879"><span region="Default">we get to spend the last night<br/>of The Eras Tour</span></p>
      <p
        begin="00:09:05.963"
        end="00:09:09.007"><span region="Default">with 60,000 beautiful people in Vancouver.</span></p>
      <p
        begin="00:09:09.091"
        end="00:09:11.093"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:09:26.191"
        end="00:09:27.442"><span region="Default">I guess what I'm tryin' to say</span></p>
      <p
        begin="00:09:27.526"
        end="00:09:29.361"><span region="Default">is you're making me feel like<br/>I'm The Man.</span></p>
      <p
        begin="00:09:29.444"
        end="00:09:30.445"><span region="Default">[crowd cheering]</span></p>
      <p
        begin="00:09:31.280"
        end="00:09:33.031"><span region="Default">[♪ "The Man" playing]</span></p>
      <p
        begin="00:09:33.115"
        end="00:09:36.785"><span region="Default">♪ I would be complex<br/>I would be cool ♪</span></p>
      <p
        begin="00:09:37.578"
        end="00:09:41.790"><span region="Default">♪ They'd say I played the field<br/>Before I found someone to commit to ♪</span></p>
      <p
        begin="00:09:41.874"
        end="00:09:45.252"><span region="Default">♪ And that would be okay<br/>For me to do ♪</span></p>
      <p
        begin="00:09:46.420"
        end="00:09:50.424"><span region="Default">♪ Every conquest I had made<br/>Would make me more of a boss to you ♪</span></p>
      <p
        begin="00:09:52.009"
        end="00:09:55.596"><span region="Default">♪ I'd be a fearless leader<br/>I'd be an alpha type ♪</span></p>
      <p
        begin="00:09:56.305"
        end="00:10:00.100"><span region="Default">♪ When everyone believes ya<br/>What's that like? ♪</span></p>
      <p
        begin="00:10:00.184"
        end="00:10:03.020"><span region="Default">♪ I'm so sick of running<br/>as fast as I can ♪</span></p>
      <p
        begin="00:10:04.271"
        end="00:10:07.816"><span region="Default">♪ Wondering if I'd get there quicker<br/>if I was a man ♪</span></p>
      <p
        begin="00:10:08.817"
        end="00:10:11.528"><span region="Default">♪ And I'm so sick of them<br/>coming at me again ♪</span></p>
      <p
        begin="00:10:12.821"
        end="00:10:14.239"><span region="Default">♪ 'Cause if I was a man ♪</span></p>
      <p
        begin="00:10:14.823"
        end="00:10:18.076"><span region="Default">♪ Then I'd be the man<br/>I'd be the man ♪</span></p>
      <p
        begin="00:10:18.160"
        end="00:10:19.328"><span region="Default">♪ Man ♪</span></p>
      <p
        begin="00:10:21.038"
        end="00:10:23.040"><span region="Default">-♪ I'd be the man ♪<br/>-♪ Man ♪</span></p>
      <p
        begin="00:10:25.459"
        end="00:10:29.004"><span region="Default">♪ They'd say I hustled<br/>Put in the work ♪</span></p>
      <p
        begin="00:10:29.963"
        end="00:10:34.176"><span region="Default">♪ They wouldn't shake their heads<br/>And question how much of this I deserve ♪</span></p>
      <p
        begin="00:10:34.259"
        end="00:10:37.721"><span region="Default">♪ What I was wearing<br/>If I was rude ♪</span></p>
      <p
