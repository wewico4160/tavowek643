      <p
        begin="02:48:17.389"
        end="02:48:21.393"><span region="Default">[♪ memainkan muzik piano lembut ]</span></p>
      <p
        begin="02:48:30.736"
        end="02:48:33.822"><span region="Default">[sorakan orang ramai]</span></p>
      <p
        begin="02:48:36.491"
        end="02:48:39.119"><span region="Default">-[♪ "Long Live" dimainkan ]<br/>-♪ Aku berkata, "Ingatlah saat ini" ♪</span></p>
      <p
        begin="02:48:39.203"
        end="02:48:41.955"><span region="Default">[sorakan orang ramai lebih kuat]</span></p>
      <p
        begin="02:48:42.039"
        end="02:48:44.666"><span region="Default">♪ Di lubuk hatiku ♪</span></p>
      <p
        begin="02:48:46.793"
        end="02:48:49.713"><span region="Default">♪ Kita berdiri dengan tangan terketar-ketar ♪</span></p>
      <p
        begin="02:48:49.796"
        end="02:48:53.967"><span region="Default">♪ Orang ramai di tempat duduk menjadi gila ♪</span></p>
      <p
        begin="02:48:54.051"
        end="02:48:56.470"><span region="Default">[sorakan orang ramai]</span></p>
      <p
        begin="02:48:56.553"
        end="02:48:59.389"><span region="Default">♪ Kita adalah raja dan ratu ♪</span></p>
      <p
        begin="02:49:01.391"
        end="02:49:04.436"><span region="Default">♪ Dan mereka membacakan nama kita ♪</span></p>
      <p
        begin="02:49:06.188"
        end="02:49:09.858"><span region="Default">♪ Ia adalah pengakhiran sebuah era ♪</span></p>
      <p
        begin="02:49:09.942"
        end="02:49:11.735"><span region="Default">[sorakan orang ramai]</span></p>
      <p
        begin="02:49:11.818"
        end="02:49:14.071"><span region="Default">♪ Tetapi permulaan sebuah zaman ♪</span></p>
      <p
        begin="02:49:16.323"
        end="02:49:19.660"><span region="Default">♪ Kau mendongak seperti seorang wira ♪</span></p>
      <p
        begin="02:49:21.828"
        end="02:49:24.373"><span region="Default">♪ Di halaman buku sejarah ♪</span></p>
      <p
        begin="02:49:31.213"
        end="02:49:36.635"><span region="Default">♪ Dan aku menjerit<br/>"Hidupilah tembok yang kita runtuhkan" ♪</span></p>
      <p
        begin="02:49:36.718"
        end="02:49:41.014"><span region="Default">♪ Bagaimana cahaya kerajaan bersinar<br/>Hanya untukku dan kamu ♪</span></p>
      <p
        begin="02:49:41.765"
        end="02:49:46.895"><span region="Default">♪ Aku menjerit<br/>"Hidupilah semua keajaiban yang kita cipta" ♪</span></p>
      <p
        begin="02:49:46.979"
        end="02:49:50.148"><span region="Default">♪ Bawakan semua penyamar ♪</span></p>
      <p
        begin="02:49:50.732"
        end="02:49:52.776"><span region="Default">♪ Suatu hari nanti ♪</span></p>
      <p
        begin="02:49:55.195"
        end="02:49:58.282"><span region="Default">♪ Kita akan diingati ♪</span></p>
      <p
        begin="02:49:58.365"
        end="02:50:04.288"><span region="Default">[sorakan orang ramai]</span></p>
      <p
        begin="02:50:08.250"
        end="02:50:10.127"><span region="Default">[♪ "New Years Day" dimainkan ]</span></p>
      <p
        begin="02:50:10.210"
        end="02:50:13.213"><span region="Default">♪ Ada glitter di lantai<br/>Selepas parti ♪</span></p>
      <p
        begin="02:50:15.382"
        end="02:50:18.594"><span region="Default">♪ Gadis-gadis membawa kasut mereka<br/>Di lobi ♪</span></p>
      <p
        begin="02:50:20.512"
        end="02:50:24.516"><span region="Default">♪ Lilin dan Polaroid<br/>Di lantai kayu keras ♪</span></p>
      <p
        begin="02:50:25.684"
        end="02:50:28.395"><span region="Default">♪ Kau dan aku dari malam sebelumnya, tetapi ♪</span></p>
      <p
        begin="02:50:29.021"
        end="02:50:34.193"><span region="Default">♪ Jangan baca halaman terakhir ♪</span></p>
      <p
        begin="02:50:34.276"
        end="02:50:39.865"><span region="Default">♪ Tetapi aku kekal apabila kau hilang<br/>Dan aku takut dan kau berpaling ♪</span></p>
      <p
        begin="02:50:39.948"
        end="02:50:44.912"><span region="Default">♪ Aku mahukan tengah malammu ♪</span></p>
      <p
        begin="02:50:44.995"
        end="02:50:49.917"><span region="Default">♪ Tetapi aku akan membersihkan botol bersamamu<br/>Pada Hari Tahun Baru ♪</span></p>
